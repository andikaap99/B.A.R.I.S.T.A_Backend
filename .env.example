# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.your-project:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres

# MinIO (via S3 API)
MINIO_ENDPOINT=your_nginx_lb_ip_or_domain
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_DSS=dss-results
MINIO_BUCKET_MODEL=ml-models

# App
APP_ENV=development
SECRET_KEY=your_secret_key_for_jwt
